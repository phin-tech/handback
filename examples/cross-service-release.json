{
  "$schema": "https://raw.githubusercontent.com/phin-tech/handback/main/schema/task.schema.json",
  "title": "Ship v2.4 across services",
  "steps": [
    {
      "id": "migrate",
      "title": "Apply the v2.4 DB migration",
      "source": { "kind": "repo", "label": "phin-tech/schema", "href": "https://github.com/phin-tech/schema/pull/84" },
      "note": "Additive only — adds tenant_tier and backfills nulls to free. Safe to run during traffic; no lock on orders.",
      "body": "Run it against the primary, then sanity-check the row count.",
      "commands": ["./migrate up --version 2.4"],
      "checks": [
        { "id": "merged", "label": "phin-tech/schema#84 is merged", "kind": "github_pr_merged", "owner": "phin-tech", "repo": "schema", "number": 84 }
      ],
      "confirms": [{ "id": "applied", "label": "Migration applied cleanly on the primary", "required": true }],
      "inputs": [{ "id": "rows", "label": "Rows affected", "kind": "text" }]
    },
    {
      "id": "orders",
      "title": "Deploy orders service",
      "requires": ["migrate"],
      "source": { "kind": "repo", "label": "phin-tech/orders-svc", "href": "https://github.com/phin-tech/orders-svc/pull/88" },
      "body": "Reads tenant_tier, so it has to go out after the migration.",
      "commands": ["./deploy orders --tag v2.4"],
      "checks": [
        { "id": "merged", "label": "phin-tech/orders-svc#88 is merged", "kind": "github_pr_merged", "owner": "phin-tech", "repo": "orders-svc", "number": 88 }
      ],
      "confirms": [{ "id": "healthz", "label": "orders /healthz returns 200 after rollout", "required": true }]
    },
    {
      "id": "flag",
      "title": "Turn on tiered pricing",
      "requires": ["orders"],
      "source": { "kind": "tool", "label": "LaunchDarkly · production" },
      "note": "Ramp to 10% first and watch the orders error rate for ~5 min before going to 100%. If anything spikes, kill the flag — it's safe to toggle off, the old path still works.",
      "body": "Flip tiered_pricing for production. If the ramp misbehaves, switch to the fallback.",
      "paths": [
        {
          "id": "ramp",
          "label": "Ramp the flag",
          "links": [{ "label": "LaunchDarkly flag", "href": "https://app.launchdarkly.com" }],
          "confirms": [{ "id": "ramped", "label": "Flag at 100%, error rate steady", "required": true }]
        },
        {
          "id": "rollback",
          "label": "Roll back",
          "outcome": "rolled back",
          "body": "Toggle the flag off — checkout falls back to flat pricing and stays healthy. The merge check stays red; that's expected. Open a follow-up so we can retry the ramp later.",
          "links": [{ "label": "Open follow-up issue", "href": "https://github.com/phin-tech/orders-svc/issues/new" }],
          "confirms": [{ "id": "flagoff", "label": "Flag is off, service healthy", "required": true }]
        }
      ]
    },
    {
      "id": "checkout",
      "title": "Deploy checkout service",
      "requires": ["migrate", "orders"],
      "source": { "kind": "repo", "label": "phin-tech/checkout-svc", "href": "https://github.com/phin-tech/checkout-svc/pull/91" },
      "body": "Calls orders for tier pricing — needs the migration and orders live first.",
      "commands": ["./deploy checkout --tag v2.4"],
      "checks": [
        { "id": "merged", "label": "phin-tech/checkout-svc#91 is merged", "kind": "github_pr_merged", "owner": "phin-tech", "repo": "checkout-svc", "number": 91 }
      ],
      "confirms": [{ "id": "e2e", "label": "A test checkout completed end-to-end", "required": true }],
      "inputs": [{ "id": "notes", "label": "Deploy notes", "kind": "textarea" }]
    },
    {
      "id": "wrap",
      "title": "Announce & close out",
      "requires": ["flag", "checkout"],
      "source": { "kind": "tool", "label": "Slack · Linear" },
      "body": "Post the release note and move the ticket to Done.",
      "links": [
        { "label": "#releases", "href": "https://slack.com" },
        { "label": "PHIN-2041", "href": "https://linear.app" }
      ],
      "confirms": [
        { "id": "posted", "label": "Posted in #releases", "required": true },
        { "id": "ticket", "label": "Linear ticket moved to Done" }
      ],
      "inputs": [{ "id": "note_link", "label": "Release note link", "kind": "text" }]
    }
  ]
}
