{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "svelte"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "ui/src/**/*.ts", "ui/src/**/*.svelte", "vite.config.ts"]
}
